--- !u!114 &361055520
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 361055518}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cf82a1b9987c148d98b150014de02f98, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DonationQueue
  entries:
  - donationText: "\u0421\u0430\u043B\u0430\u043C \u043A\u0430\u0440\u0442\u0430.
      \u0413\u043E \u043D\u0430 \u0431\u0430\u043B \u043F\u0430\u043B\u0430\u0434\u0438\u043D\u0435.
      \u0414\u0435\u043A\u0430 \u043F\u0440\u0438\u043A\u043E\u043B\u044C\u043D\u0430\u044F
      \u0438 \u0442\u043E\u043F 1 \u043F\u043E \u0432\u0440 \u0441\u0435\u0439\u0447\u0430\u0441.
      \u0415\u0441\u043B\u0438 \u043D\u0435\u0442 \u0442\u043E \u043A\u0430\u043A
      \u0432 \u0446\u0435\u043B\u043E\u043C \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435?
      \u0421\u043C\u043E\u0442\u0440\u0435\u043B \u0442\u0435\u0431\u044F \u0432\u043E
      \u0432\u0440\u0435\u043C\u0435\u043D\u0430, \u043A\u043E\u0433\u0434\u0430
      \u0434\u0430\u0432\u0430\u0439 \u0440\u0435\u0439\u0434\u044B \u043D\u0430
      \u0431\u0440\u0430\u0442\u0430,"
    videoClip: {fileID: 32900000, guid: c011157e160244d7d82a702e0d6603d9, type: 3}
  - donationText: "\u0414\u043E\u0432\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u043B\u0438
      \u0432\u0430\u043C \u0438\u0433\u0440\u0430\u0442\u044C \u043D\u0430 \u0431\u0430\u0431\u043B
      \u043F\u0430\u043B\u0430\u0434\u0438\u043D\u0435? \u0422\u043E\u043F 1 \u0432\u0440.
      \u0422\u043E\u043F 1 \u0432\u0440. \u0412\u0430\u0441 \u0434\u0435\u0440\u0436\u0430\u0442
      \u0432 \u043A\u043B\u0435\u0442\u043A\u0435? \u0411\u0430\u0431\u043B \u043F\u0430\u043B\u0430\u0434\u0438\u043D.
      \u0411\u0430\u0431\u043B \u043F\u0430\u043B\u0430\u0434\u0438\u043D. \u043A\u0430\u043A
      \u0432 \u0446\u0435\u043B\u043E\u043C \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435?
      \u0414\u0435\u043A\u0430 \u043F\u0440\u0438\u043A\u043E\u043B\u044C\u043D\u0430\u044F.
      \u0414\u0435\u043A\u0430 \u043F\u0440\u0438\u043A\u043E\u043B\u044C\u043D\u0430\u044F.
      \u0412\u044B \u0436\u0430\u0436\u0434\u0435\u0442\u0435 \u0441\u044B\u0433\u0440\u0430\u0442\u044C
      \u043D\u0430 \u0431\u0430\u0431\u043B \u043F\u0430\u043B\u0430\u0434\u0438\u043D\u0435?
      \u0414\u0435\u043A\u0430 \u043F\u0440\u0438\u043A\u043E\u043B\u044C\u043D\u0430\u044F.
      \u0414\u0435\u043A\u0430 \u043F\u0440\u0438\u043A\u043E\u043B\u044C\u043D\u0430\u044F.
      \u0412\u0430\u043C \u0441\u043D\u0438\u0442\u0441\u044F \u0442\u043E\u043F
      1 \u0432\u0440? \u0411\u0430\u0431\u043B \u043F\u0430\u043B\u0430\u0434\u0438\u043D.
      \u0411\u0430\u0431\u043B \u043F\u0430\u043B\u0430\u0434\u0438\u043D"
    videoClip: {fileID: 32900000, guid: 45b0acb6cd6614d3293c0c2559bca6cc, type: 3}
  - donationText: "\u0411\u0430\u0431 \u041F\u0430\u0434\u0438\u043D \u0411\u0430\u0431\u0430
      \u0414\u0438\u043D \u041B\u0430\u0431\u0430 \u0414\u0438\u043D \u0411\u0430\u043B\u0430
      \u041F\u0434\u0438\u043D \u0411\u0438\u0431\u043B \u0414\u0430\u043D \u0411\u0430\u0431\u043B
      \u0414\u0438\u043D \u0413\u043E \u0413\u043E \u0413\u043E \u0421\u0438\u043B\u044C
      \u0411\u0430\u0431\u043B \u0427\u0438\u043A\u0430\u0439 \u0411\u0430\u0431\u043B
      \u0414\u0438\u043D \u0410\u043B\u0441\u043E \u0411\u0430\u0431\u043B \u0411\u043B\u0430
      \u0411\u043B\u0430 \u0421\u0432\u0438\u043D\u044E\u0448\u043A\u0430 \u0411\u0430\u0431\u043B
      \u041A\u0430\u0440\u0442\u0430 \u0411\u0430\u0431\u043B \u0421\u0430\u043B\u0430\u043C
      \u0411\u0430\u0431 \u0413\u043E \u043D\u0430 \u0411\u0438\u0431\u0443\u043B
      \u041F\u043E\u043B\u0430\u0434\u0438\u043D\u0435"
    videoClip: {fileID: 32900000, guid: 54d119fe816584a0bbf72c9d26a54515, type: 3}
  - donationText: "\u0421\u0432\u0438\u043D \u043C\u043E\u0439. \u0412 \u0434\u0435\u043D\u044C,
      \u043A\u043E\u0433\u0434\u0430 \u0442\u044B \u0440\u043E\u0434\u0438\u043B\u0441\u044F,
      \u0441\u0430\u043C\u0438 \u043B\u0435\u0441\u0430 \u041B\u043E\u0440\u0434\u0435\u0440\u043E\u043D\u0430
      \u043F\u0440\u043E\u0448\u0435\u043F\u0442\u0430\u043B\u0438: \u0433\u043E
      \u043D\u0430 \u0431\u0430\u0431\u043B \u043F\u0430\u043B\u0430\u0434\u0438\u043D\u0435.
      \u0414\u044D\u043A\u0430 \u043F\u0440\u0438\u043A\u043E\u043B\u044C\u043D\u0430\u044F
      \u0438 \u0442\u043E\u043F 1 \u043F\u043E \u0432\u0440 \u0441\u0435\u0439\u0447\u0430\u0441.
      \u0415\u0441\u043B\u0438 \u043D\u0435\u0442 \u0442\u043E \u0432 \u0446\u0435\u043B\u043E\u043C
      \u043A\u0430\u043A \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435?
      \u0421\u043C\u043E\u0442\u0440\u0435\u043B \u0442\u0435\u0431\u044F \u0432\u043E
      \u0432\u0440\u0435\u043C\u0435\u043D\u0430 \u043A\u043E\u0433\u0434\u0430 \u043F\u0443\u0433\u0430\u043B
      \u0441\u043E\u0432\u043E\u0439. \u043D\u0430\u043F\u0443\u0433\u0430\u0439
      \u043D\u0430\u0441 \u0441\u043E\u0432\u043E\u043E\u043E\u043E\u043E\u043E\u0439"
    videoClip: {fileID: 32900000, guid: 45a38832bafcd4502930b9ca7d932a09, type: 3}
  - donationText: Salam karta. Go na bal paladine. Deka prikolnaya i top 1 po vr
      seychas. Esli net to kak v tselom nastoyeniye? Smotrel tebya vo vremena, kogda
      davay reydy na brata.
    videoClip: {fileID: 32900000, guid: 491159528a4ea46fa92aeaeb69f3c62b, type: 3}
  - donationText: "\u0445\u043E\u0447\u0443 \u0437\u0430\u043A\u0430\u0437\u0430\u0442\u044C
      \u043F\u0435\u0441\u043D\u044E \u0435\u0441\u043B\u0438 \u043C\u043E\u0436\u043D\u043E
      \u043F\u043E\u0441\u0442\u0430\u0432\u044C \u0447\u0442\u043E \u043D\u0438\u0431\u0443\u0434\u044C
      \u0432\u0435\u0441\u0451\u043B\u043E\u0435 \u043C\u044B \u0442\u0443\u0442
      \u0432\u0441\u0435\u0439 \u0441\u0435\u043C\u044C\u0451\u0439 \u0441\u043C\u043E\u0442\u0440\u0438\u043C
      \u0438 \u0445\u043E\u0442\u0438\u043C \u043F\u043E\u0442\u0430\u043D\u0446\u0435\u0432\u0430\u0442\u044C"
    videoClip: {fileID: 0}
  - donationText: "\u0441\u0442\u0440\u0438\u043C\u0435\u0440 \u0442\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F
      \u043E\u0447\u0435\u043D\u044C \u0445\u043E\u0440\u043E\u0448\u043E \u0438\u0433\u0440\u0430\u0435\u0448\u044C
      \u044D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0433\u043E\u043D\u044C
      \u043C\u044B \u0432 \u0447\u0430\u0442\u0435 \u0431\u043E\u043B\u0435\u0435\u043C
      \u0437\u0430 \u0442\u0435\u0431\u044F \u043D\u0435 \u0441\u0434\u0430\u0432\u0430\u0439\u0441\u044F
      \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0439"
    videoClip: {fileID: 0}
  - donationText: "\u0437\u0430\u043B\u0443\u043F\u0430 \u043A\u0430\u043B \u043A\u0430\u043A\u0448\u043A\u0438
      \u0447\u043C\u043E\u043E\u043E\u043E"
    videoClip: {fileID: 0}
